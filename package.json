{
  "name": "alpha-warrior",
  "version": "2.0.0",
  "description": "Secure Autonomous Agent utilizing OpenClaw and validated by ArmorClaw for Intent-Aware Runtime Enforcement.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "prod": "concurrently \"python3 -m uvicorn SentinelLayer.backend.main:app --port 8000 --host 0.0.0.0\" \"node src/index.js\"",
    "build": "pip3 install -r requirements.txt",
    "dev": "node --watch src/index.js",
    "dashboard": "node src/dashboard/server.js",
    "demo:attack": "node src/attacks/demo.js",
    "run:industry": "node src/industry_run.js",
    "test": "node src/tests/run.js",
    "test:security": "node src/tools/red_team.js"
  },
  "dependencies": {
    "@slack/bolt": "^3.18.0",
    "chalk": "^5.3.0",
    "concurrently": "^9.2.1",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
